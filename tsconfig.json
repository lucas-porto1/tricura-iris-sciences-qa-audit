{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "noEmit": true
  },
  "include": ["tests/**/*.ts", "playwright.config.ts"]
}